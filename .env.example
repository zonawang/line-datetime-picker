# LINE Bot Configuration Example
# Please rename this file to .env and fill in the values from LINE Developers Console.

PORT=3000

# LINE Channel Secret (Basic settings -> Channel secret)
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE Channel Access Token (Messaging API -> Channel access token)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Optional: Deity Custom Icon URLs (Icon Switch)
# Please replace these with your own custom HTTPS image URLs later
DEITY_APOLLO_ICON=https://images.unsplash.com/photo-1614730321146-b6fa6a46bcb4?auto=format&fit=crop&w=128&h=128&q=80
DEITY_VENUS_ICON=https://images.unsplash.com/photo-1614313913007-2b4ae8ce32d6?auto=format&fit=crop&w=128&h=128&q=80
DEITY_FORTUNE_ICON=https://images.unsplash.com/photo-1506318137071-a8e063b4bec0?auto=format&fit=crop&w=128&h=128&q=80
DEITY_COSMOS_ICON=https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?auto=format&fit=crop&w=128&h=128&q=80

